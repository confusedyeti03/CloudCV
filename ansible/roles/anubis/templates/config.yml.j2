# =============================================================================
# Anubis PoW Configuration
# =============================================================================
# Purpose: Proof-of-Work challenge configuration
# Generated by Ansible - DO NOT edit manually
#
# WHAT EACH PARAMETER DOES:
# - difficulty: Number of zeros in hash (higher = more CPU required)
#   - 2-3: Very easy (milliseconds)
#   - 4-5: Recommended balance (1-5 seconds)
#   - 6+: Very difficult (may frustrate users)
# - bind: Address:port where Anubis listens
# - target: Backend to redirect to after the challenge
# =============================================================================

# Proof-of-Work difficulty
# The client must find a hash with {{ anubis_difficulty }} leading zeros
difficulty: {{ anubis_difficulty }}

# Port where Anubis listens (localhost only for security)
bind: "{{ anubis_bind }}"

# Backend after the challenge (Nginx or directly the app)
target: "{{ anubis_target }}"

# Allow legitimate robots (Googlebot, Bingbot) without PoW
# These bots identify themselves by User-Agent and IP
robots_txt_passthrough: true

# Validity time of the completed challenge (seconds)
# After this time, the user will need to do the challenge again
cookie_expiry: 86400  # 24 hours
