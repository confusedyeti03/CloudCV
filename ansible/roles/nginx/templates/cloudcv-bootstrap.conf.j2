# =============================================================================
# CloudCV Bootstrap Configuration (HTTP only - pre-SSL)
# =============================================================================
# Purpose: Initial config for obtaining Let's Encrypt certificate
# After certbot runs, this is replaced by the full SSL config
# =============================================================================

server {
    listen 80;
    listen [::]:80;
    server_name {{ nginx_domain }} www.{{ nginx_domain }};

    root {{ nginx_web_root }};
    index index.html;

    # Let's Encrypt ACME challenge
    location /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
    }

    # Serve static content
    location / {
        try_files $uri $uri/ =404;
    }

    location /cv/ {
        try_files $uri $uri/ /cv/index.html;
    }

    location /portfolio/ {
        try_files $uri $uri/ /portfolio/index.html;
    }
}
