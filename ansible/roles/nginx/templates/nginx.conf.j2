# =============================================================================
# Nginx Main Configuration
# =============================================================================
# Purpose: Global Nginx configuration
# Generated by Ansible - DO NOT edit manually
# =============================================================================

user www-data;
worker_processes auto;
pid /run/nginx.pid;
include /etc/nginx/modules-enabled/*.conf;

events {
    # Simultaneous connections per worker
    worker_connections 1024;
}

http {
    # -------------------------------------------------------------------------
    # MIME Types and basic configuration
    # -------------------------------------------------------------------------
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    # Performance optimizations
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    types_hash_max_size 2048;

    # -------------------------------------------------------------------------
    # GZIP: Compression to reduce bandwidth
    # -------------------------------------------------------------------------
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml;

    # -------------------------------------------------------------------------
    # CLOUDFLARE: Real IP
    # -------------------------------------------------------------------------
    # Cloudflare acts as a proxy, we need the real client IP
    # CF-Connecting-IP contains the original visitor IP
    real_ip_header CF-Connecting-IP;
    {% for cidr in nginx_cloudflare_ips %}
    set_real_ip_from {{ cidr }};
    {% endfor %}

    # -------------------------------------------------------------------------
    # RATE LIMITING: Zones to limit requests
    # -------------------------------------------------------------------------
    # Protection against abuse and DDoS
    # Zone 'general': 10 req/s per IP for static content
    # Zone 'api': 5 req/s per IP for API (more restrictive)
    limit_req_zone $binary_remote_addr zone=general:10m rate={{ nginx_rate_limit_general }};
    limit_req_zone $binary_remote_addr zone=api:10m rate={{ nginx_rate_limit_api }};
    limit_req_zone $binary_remote_addr zone=pdf:10m rate={{ nginx_rate_limit_pdf }};
    limit_req_status 429;

    # -------------------------------------------------------------------------
    # LOGS: Access and error logging
    # -------------------------------------------------------------------------
    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;

    # -------------------------------------------------------------------------
    # INCLUDES: Additional configurations and sites
    # -------------------------------------------------------------------------
    include /etc/nginx/conf.d/*.conf;
    include /etc/nginx/sites-enabled/*;
}
