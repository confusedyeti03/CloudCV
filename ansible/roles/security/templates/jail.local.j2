# =============================================================================
# Fail2ban Configuration Template
# =============================================================================
# Purpose: Protect SSH against brute force attacks with temporary bans
# Generated by Ansible - DO NOT edit manually
# =============================================================================

[DEFAULT]
# Ban duration in seconds (1 hour)
bantime = 3600
# Time window to count failed attempts (10 minutes)
findtime = 600
# Max failed attempts before ban
maxretry = 5

[sshd]
enabled = true
# Non-standard SSH port
port = 2222
logpath = /var/log/auth.log
