# =============================================================================
# SSHD Configuration Template
# =============================================================================
# Purpose: Harden SSH access to minimize intrusion risks
# Generated by Ansible - DO NOT edit manually
# =============================================================================

Port 2222
Protocol 2

# Disable root login to prevent direct privilege escalation
PermitRootLogin no

# Only allow key-based authentication (no passwords)
PasswordAuthentication no
PubkeyAuthentication yes

# Disable unnecessary features
X11Forwarding no

# Limit authentication attempts and keep connections alive
MaxAuthTries 3
ClientAliveInterval 300

# Basic recommended OpenSSH settings
UsePAM yes
ChallengeResponseAuthentication no
PermitEmptyPasswords no
LoginGraceTime 30
AllowTcpForwarding yes
PermitTunnel no
PrintMotd no
AcceptEnv LANG LC_*
Subsystem sftp /usr/lib/openssh/sftp-server
